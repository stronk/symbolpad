{
  "productName": "SymbolPad",
  "version": "0.2.0",
  "identifier": "com.symbolpad",
  "build": {
	"frontendDist": "../src"
  },
  "app": {
	"windows": [
	  {
		"label": "main",
		"title": "Symbol Pad",
		"width": 500,
		"height": 340,
		"decorations": false,
		"transparent": true,
		"alwaysOnTop": true,
		"visible": false,
		"resizable": false,
		"skipTaskbar": true,
		"shadow": false
	  }
	],
	"security": {
	  "capabilities": [
		{
		  "identifier": "main",
		  "description": "Main window capabilities",
		  "windows": ["main"],
		  "permissions": ["core:window:allow-set-size", "core:default"]
		}
	  ]
	}
  },
  "bundle": {
	"active": true,
	"targets": "all",
	"icon": ["icons/icon.png", "icons/icon.ico"],
	"macOS": {
	  "infoPlist": "Info.plist"
	}
  }
}