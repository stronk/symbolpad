{
  "productName": "SymbolPad",
  "version": "0.1.0",
  "identifier": "com.symbolpad",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Symbol Pad",
        "width": 500,
        "height": 320,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": true
      }
    ]
  },
  "bundle": {
	"active": true,
	"targets": "all",
	"icon": ["icons/icon.png", "icons/icon.ico"],
	"macOS": {
	  "infoPlist": "Info.plist"
	}
  }
}
